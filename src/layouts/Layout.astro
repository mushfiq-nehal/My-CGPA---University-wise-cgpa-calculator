---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description = 'Free CGPA, GPA, and Percentage Calculators for universities and grading systems worldwide. Supports Bangladesh, India, Pakistan, and more.',
  canonical,
  ogTitle,
  ogDescription,
  ogImage = '/og-image.png',
  ogImageAlt = 'MyCGPA — Calculate GPA & CGPA Instantly',
  schema,
  noindex = false,
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

const resolvedOgImage = new URL(ogImage, Astro.site);

// No potentialAction/SearchAction: the site has no ?q= search endpoint, and
// declaring one that doesn't resolve is invalid markup.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'MyCGPA',
  url: 'https://mycgpa.com/',
  description: 'Free CGPA and GPA calculators for students worldwide',
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- MUST stay first: the HTML spec's encoding pre-scan only reads the first
         1024 bytes, and the tag/analytics scripts below are far larger than that. -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Fonts: linked (not @import-ed from CSS) so the browser can start the
         fetch immediately instead of waiting for global.css to parse. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap"
    />

    <!-- Google Consent Mode v2: default to denied only where GDPR/UK-GDPR/CH-DPA
         apply (EEA + UK + Switzerland). Everywhere else defaults to granted,
         since opt-in-by-default is not required there and was tanking GA
         reporting for the vast majority of our (non-EU) visitors. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        region: ['AT','BE','BG','HR','CY','CZ','DK','EE','FI','FR','DE','GR','HU','IS','IE','IT','LV','LI','LT','LU','MT','NL','NO','PL','PT','RO','SK','SI','ES','SE','GB','CH'],
        wait_for_update: 500,
      });

      (function () {
        try {
          var stored = localStorage.getItem('cookie_consent');
          if (stored === 'accepted') {
            gtag('consent', 'update', {
              ad_storage: 'granted',
              analytics_storage: 'granted',
              ad_user_data: 'granted',
              ad_personalization: 'granted',
            });
          } else if (stored === 'rejected') {
            gtag('consent', 'update', {
              ad_storage: 'denied',
              analytics_storage: 'denied',
              ad_user_data: 'denied',
              ad_personalization: 'denied',
            });
          }
        } catch (e) {}
      })();
    </script>

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1817502704498215" crossorigin="anonymous"></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JXDHDBV44W"></script>
    <script is:inline>
      gtag('js', new Date());
      gtag('config', 'G-JXDHDBV44W');
    </script>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyCGPA" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex
      ? <meta name="robots" content="noindex, follow" />
      : <link rel="canonical" href={canonicalURL.href} />}
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={resolvedOgImage.href} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="MyCGPA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:image" content={resolvedOgImage.href} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {schema && (Array.isArray(schema) ? schema : [schema]).map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
