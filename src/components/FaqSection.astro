---
// One `question` field only: a separate schema-vs-display string invites the
// two to drift apart, which is a structured-data mismatch.
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FaqItem[];
}

const { faqs } = Astro.props;
---

<section class="faq-section" aria-labelledby="faq-section-heading">
  <div class="container-page">
    <div class="faq-section-inner">
      <div class="faq-header">
        <span class="caption-mono faq-eyebrow">Frequently Asked Questions</span>
        <h2 class="display-lg" id="faq-section-heading">Got Questions? We’ve Got Answers.</h2>
        <p class="body-lg faq-sub">Learn more about calculating CGPA, conversions, and how to use our tool effectively.</p>
      </div>

      <div class="faq-list">
        {faqs.map((f, i) => (
          <details class="faq-item" id={`faq-item-${i}`}>
            <summary class="faq-question">
              <span>{f.question}</span>
              <svg class="faq-arrow" width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="faq-answer-content">
              <p class="faq-answer" set:html={f.answer}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding-block: var(--spacing-5xl);
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
  }

  .faq-section-inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4xl);
    max-width: 800px;
    margin-inline: auto;
  }

  .faq-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .faq-eyebrow {
    color: var(--color-mute);
  }

  .faq-header h2 {
    margin: 0;
    color: var(--color-ink);
  }

  .faq-sub {
    margin: 0;
    color: var(--color-body);
    max-width: 580px;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-hairline);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-hairline);
    transition: background-color 0.2s ease;
  }

  .faq-item:hover {
    background-color: var(--color-canvas-soft);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    padding: var(--spacing-lg) var(--spacing-md);
    font-size: 17px;
    font-weight: 550;
    color: var(--color-ink);
    cursor: pointer;
    list-style: none;
    letter-spacing: -0.4px;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-arrow {
    flex-shrink: 0;
    color: var(--color-mute);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), color 0.2s ease;
  }

  .faq-item:hover .faq-arrow {
    color: var(--color-ink);
  }

  details[open] .faq-arrow {
    transform: rotate(180deg);
    color: var(--color-ink);
  }

  .faq-answer-content {
    padding-inline: var(--spacing-md);
    padding-bottom: var(--spacing-lg);
  }

  .faq-answer {
    margin: 0;
    font-size: 15.5px;
    color: var(--color-body);
    line-height: 1.65;
  }

  /* Deep styled content inside answer (like code tags, links, lists etc.) */
  .faq-answer :global(code) {
    font-family: var(--font-mono);
    font-size: 13.5px;
    background-color: var(--color-canvas-soft-2);
    padding: 2px 6px;
    border-radius: var(--radius-xs);
    color: var(--color-ink);
    border: 1px solid var(--color-hairline);
  }

  .faq-answer :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  @media (max-width: 599px) {
    .faq-question {
      padding: var(--spacing-md);
      font-size: 16px;
    }
    .faq-answer-content {
      padding-inline: var(--spacing-md);
      padding-bottom: var(--spacing-md);
    }
    .faq-answer {
      font-size: 14.5px;
    }
  }
</style>
