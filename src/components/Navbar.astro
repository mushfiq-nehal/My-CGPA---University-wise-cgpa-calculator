---
const navLinks = [
  { href: '/#calculator', label: 'Calculator' },
  { href: '/universities', label: 'Universities' },
  { href: '/#formula', label: 'How It Works' },
];
const currentPath = Astro.url.pathname;
---

<header class="navbar" id="site-nav" role="banner">
  <div class="navbar-inner container-page">
    <!-- Logo -->
    <a href="/" class="navbar-logo" aria-label="MyCGPA Home">
      <span class="logo-text">MyCGPA</span>
      <span class="logo-dot" aria-hidden="true">.com</span>
    </a>

    <!-- Desktop Nav Links -->
    <nav class="navbar-links" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href ? 'nav-link--active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Nav Actions (Theme Toggle & CTA / Burger) -->
    <div class="navbar-actions">
      <button
        id="theme-toggle"
        class="theme-toggle-btn"
        aria-label="Toggle dark mode"
      >
        <!-- Sun icon (visible in dark mode) -->
        <svg class="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="M4.93 4.93l1.41 1.41"></path>
          <path d="M17.66 17.66l1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="M6.34 17.66l-1.41 1.41"></path>
          <path d="M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <!-- Moon icon (visible in light mode) -->
        <svg class="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <div class="navbar-cta">
        <a href="/#calculator" class="btn-cta" id="nav-calculate-btn">
          Calculate CGPA
        </a>
      </div>

      <!-- Mobile Menu Toggle -->
      <button
        class="mobile-menu-toggle"
        id="mobile-menu-toggle"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-nav-link">{link.label}</a>
      ))}
      <a href="/#calculator" class="mobile-cta">Calculate CGPA</a>
    </nav>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    height: 64px;
    background: var(--color-navbar-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-hairline);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: var(--spacing-lg);
  }

  .navbar-logo {
    display: flex;
    align-items: baseline;
    gap: 2px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.5px;
  }

  .logo-dot {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-mute);
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    flex: 1;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-body);
    text-decoration: none;
    border-radius: var(--radius-full);
    transition: background-color 0.15s ease, color 0.15s ease;
    letter-spacing: -0.28px;
  }

  .nav-link:hover {
    background-color: var(--color-canvas-soft-2);
    color: var(--color-ink);
  }

  .nav-link--active {
    color: var(--color-ink);
    font-weight: 500;
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-left: auto;
  }

  .theme-toggle-btn {
    background: none;
    border: none;
    padding: var(--spacing-xxs);
    cursor: pointer;
    color: var(--color-ink);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    transition: background-color 0.15s ease, transform 0.15s ease, color 0.15s ease;
  }

  .theme-toggle-btn:hover {
    background-color: var(--color-canvas-soft-2);
    transform: scale(1.05);
  }

  .theme-toggle-btn svg {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  html.dark .theme-toggle-btn svg {
    transform: rotate(45deg);
  }

  /* Theme Icon Toggle Logic */
  html:not(.dark) .sun-icon {
    display: none;
  }
  html.dark .moon-icon {
    display: none;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    height: 28px;
    padding: 0 var(--spacing-xs);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-on-primary);
    background-color: var(--color-ink);
    border-radius: var(--radius-sm);
    text-decoration: none;
    letter-spacing: -0.28px;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .btn-cta:hover {
    opacity: 0.85;
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--spacing-xs);
    margin-left: auto;
  }

  .hamburger-bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background-color: var(--color-ink);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mobile-menu {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: var(--spacing-md) var(--spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .mobile-nav-link {
    display: block;
    padding: var(--spacing-sm) 0;
    font-size: 16px;
    color: var(--color-body);
    text-decoration: none;
    border-bottom: 1px solid var(--color-hairline);
  }

  .mobile-nav-link:last-of-type {
    border-bottom: none;
  }

  .mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-lg);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-on-primary);
    background-color: var(--color-ink);
    border-radius: var(--radius-sm);
    text-decoration: none;
  }

  @media (max-width: 767px) {
    .navbar {
      height: auto;
      min-height: 56px;
    }

    .navbar-inner {
      height: 56px;
    }

    .navbar-links,
    .navbar-cta {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  // Mobile Menu Logic
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.hidden;
    if (menu) menu.hidden = isOpen;
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (menu) menu.hidden = true;
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Dark Mode Toggle Logic
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  });
</script>
