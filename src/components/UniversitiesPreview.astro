---
import { UNIVERSITIES } from '../data/universities';
import UniversityCard from './UniversityCard.astro';

const featured = UNIVERSITIES.slice(0, 6);
---

<section class="unis-preview" aria-labelledby="unis-heading">
  <div class="container-page">
    <div class="unis-header">
      <div class="unis-header-text">
        <span class="caption-mono unis-eyebrow">Universities</span>
        <h2 class="display-lg" id="unis-heading">University-specific calculators.</h2>
        <p class="body-lg unis-sub">
          Calculators pre-loaded with your university's grading system. Bangladesh, India, and Pakistan.
        </p>
      </div>
      <a href="/universities/" class="btn-view-all" id="view-all-universities-btn">
        View all universities
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="unis-grid">
      {featured.map(u => <UniversityCard university={u} />)}
    </div>

    <div class="unis-footer">
      <a href="/universities/" class="btn-hero-secondary">
        Browse all {UNIVERSITIES.length} universities
      </a>
    </div>
  </div>
</section>

<style>
  .unis-preview {
    padding-block: var(--spacing-5xl);
    background-color: var(--color-canvas-soft);
  }

  .unis-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-3xl);
    flex-wrap: wrap;
  }

  .unis-header-text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .unis-eyebrow { color: var(--color-mute); }

  .unis-header-text h2 { margin: 0; color: var(--color-ink); }

  .unis-sub { margin: 0; color: var(--color-body); max-width: 440px; }

  .btn-view-all {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--color-hairline);
    transition: border-color 0.15s;
    letter-spacing: -0.28px;
  }

  .btn-view-all:hover { border-color: var(--color-ink); }

  .unis-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .unis-footer {
    display: flex;
    justify-content: center;
    margin-top: var(--spacing-3xl);
  }

  .btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 var(--spacing-lg);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-ink);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }

  .btn-hero-secondary:hover {
    border-color: var(--color-hairline-strong);
    transform: translateY(-1px);
  }

  @media (max-width: 899px) {
    .unis-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 599px) {
    .unis-grid { grid-template-columns: 1fr; }
    .unis-header { flex-direction: column; align-items: flex-start; }
  }
</style>
