---
// A fully derived worked example: every grade, point value and total below is
// computed from the university's own GradingSystem entries, so this cannot
// drift out of sync with the scale shown elsewhere on the page and contains
// no hand-written academic claims.
import type { GradingSystem } from '../data/gradingSystems';

interface Props {
  gradingSystem: GradingSystem;
  shortName: string;
}

const { gradingSystem, shortName } = Astro.props;

// Pick a spread of real grades from this scale: best, a mid-upper, and a mid.
const passing = gradingSystem.entries.filter(e => e.point > 0);
const pick = (i: number) => passing[Math.min(i, passing.length - 1)];
const chosen = [pick(0), pick(2), pick(4), pick(1)];
const credits = [3, 3, 2, 4];

const rows = chosen.map((e, i) => ({
  course: `Course ${i + 1}`,
  grade: e.grade,
  point: e.point,
  credits: credits[i],
  product: +(e.point * credits[i]).toFixed(2),
}));

const totalCredits = rows.reduce((s, r) => s + r.credits, 0);
const totalPoints = +rows.reduce((s, r) => s + r.product, 0).toFixed(2);
const gpa = +(totalPoints / totalCredits).toFixed(2);
---

<section class="example-section" aria-labelledby="example-heading">
  <div class="container-page">
    <span class="caption-mono example-eyebrow">Worked Example</span>
    <h2 class="display-md" id="example-heading">
      How a {shortName} GPA is calculated, step by step.
    </h2>
    <p class="body-md example-intro">
      Four courses graded on the {gradingSystem.shortName} scale. Each grade becomes a
      grade point, multiplied by that course's credit hours — then the totals are divided.
    </p>

    <div class="example-table-wrap">
      <table class="example-table">
        <caption class="sr-only">
          Worked {shortName} CGPA calculation across {rows.length} courses
        </caption>
        <thead>
          <tr>
            <th scope="col">Course</th>
            <th scope="col">Grade</th>
            <th scope="col">Grade Point</th>
            <th scope="col">Credits</th>
            <th scope="col">Points × Credits</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(r => (
            <tr>
              <th scope="row">{r.course}</th>
              <td>{r.grade}</td>
              <td>{r.point.toFixed(2)}</td>
              <td>{r.credits}</td>
              <td>{r.product.toFixed(2)}</td>
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr>
            <th scope="row" colspan="3">Total</th>
            <td>{totalCredits}</td>
            <td>{totalPoints.toFixed(2)}</td>
          </tr>
        </tfoot>
      </table>
    </div>

    <p class="body-md example-result">
      Dividing total grade points by total credits gives the semester GPA:
      <strong>{totalPoints.toFixed(2)} ÷ {totalCredits} = {gpa.toFixed(2)}</strong>
      on a {gradingSystem.maxGPA.toFixed(1)} scale. A cumulative
      {' '}{shortName} CGPA repeats this across every semester you have completed,
      using all credits earned to date.
    </p>
  </div>
</section>

<style>
  .example-section {
    padding: var(--spacing-3xl) 0;
    border-top: 1px solid var(--color-hairline);
  }

  .example-eyebrow {
    display: block;
    color: var(--color-mute);
    margin-bottom: var(--spacing-sm);
  }

  .example-intro {
    max-width: 62ch;
    color: var(--color-body);
    margin: var(--spacing-sm) 0 var(--spacing-lg);
  }

  .example-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-md);
  }

  .example-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    min-width: 480px;
  }

  .example-table th,
  .example-table td {
    padding: var(--spacing-sm) var(--spacing-md);
    text-align: left;
    border-bottom: 1px solid var(--color-hairline);
  }

  .example-table thead th {
    font-weight: 600;
    color: var(--color-ink);
    background-color: var(--color-canvas-soft-2);
  }

  .example-table tbody th {
    font-weight: 500;
    color: var(--color-body);
  }

  .example-table tfoot th,
  .example-table tfoot td {
    font-weight: 600;
    border-bottom: none;
  }

  .example-result {
    margin-top: var(--spacing-lg);
    max-width: 62ch;
    color: var(--color-body);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
