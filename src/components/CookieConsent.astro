---
// GDPR-style cookie consent banner. Wires into Google Consent Mode v2 so that
// analytics_storage / ad_storage / ad_user_data / ad_personalization stay
// "denied" until the visitor actively accepts.
---

<div class="cookie-banner" id="cookie-banner" role="dialog" aria-live="polite" aria-label="Cookie consent" hidden>
  <div class="cookie-banner-inner">
    <div class="cookie-copy">
      <p class="cookie-title">We use cookies</p>
      <p class="cookie-desc">
        We use essential cookies to run this site, and optional analytics &amp; advertising cookies (including Google AdSense) to understand usage and show relevant ads. You can accept, reject non-essential cookies, or read our
        <a href="/cookies">Cookie Policy</a>.
      </p>
    </div>
    <div class="cookie-actions">
      <button type="button" class="cookie-btn cookie-btn-ghost" id="cookie-reject">Reject non-essential</button>
      <button type="button" class="cookie-btn cookie-btn-primary" id="cookie-accept">Accept all</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    padding: var(--spacing-md);
    display: flex;
    justify-content: center;
  }

  .cookie-banner-inner {
    width: 100%;
    max-width: 920px;
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.16);
  }

  .cookie-copy {
    flex: 1;
    min-width: 0;
  }

  .cookie-title {
    margin: 0 0 4px 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-ink);
  }

  .cookie-desc {
    margin: 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-body);
  }

  .cookie-desc a {
    color: var(--color-link);
    text-decoration: underline;
  }

  .cookie-actions {
    display: flex;
    gap: var(--spacing-sm);
    flex-shrink: 0;
  }

  .cookie-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 var(--spacing-md);
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--radius-sm);
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s ease, background-color 0.15s ease;
  }

  .cookie-btn-primary {
    background-color: var(--color-ink);
    color: var(--color-on-primary);
    border: none;
  }

  .cookie-btn-primary:hover {
    opacity: 0.9;
  }

  .cookie-btn-ghost {
    background-color: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-hairline-strong);
  }

  .cookie-btn-ghost:hover {
    background-color: var(--color-canvas-soft-2);
  }

  @media (max-width: 767px) {
    .cookie-banner-inner {
      flex-direction: column;
      align-items: stretch;
      gap: var(--spacing-md);
    }

    .cookie-actions {
      flex-direction: column-reverse;
    }

    .cookie-btn {
      width: 100%;
    }
  }
</style>

<script>
  type ConsentChoice = 'accepted' | 'rejected';
  const STORAGE_KEY = 'cookie_consent';

  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  function applyConsent(choice: ConsentChoice) {
    const granted = choice === 'accepted';
    // @ts-ignore - gtag is loaded globally via inline script in Layout
    if (typeof window.gtag === 'function') {
      // @ts-ignore
      window.gtag('consent', 'update', {
        ad_storage: granted ? 'granted' : 'denied',
        analytics_storage: granted ? 'granted' : 'denied',
        ad_user_data: granted ? 'granted' : 'denied',
        ad_personalization: granted ? 'granted' : 'denied',
      });
    }
  }

  function showBanner() {
    if (banner) banner.hidden = false;
  }

  function hideBanner() {
    if (banner) banner.hidden = true;
  }

  function setChoice(choice: ConsentChoice) {
    localStorage.setItem(STORAGE_KEY, choice);
    applyConsent(choice);
    hideBanner();
  }

  const existing = localStorage.getItem(STORAGE_KEY) as ConsentChoice | null;
  if (existing === 'accepted' || existing === 'rejected') {
    applyConsent(existing);
  } else {
    showBanner();
  }

  acceptBtn?.addEventListener('click', () => setChoice('accepted'));
  rejectBtn?.addEventListener('click', () => setChoice('rejected'));

  // Allow other parts of the site (e.g. footer "Cookie Settings" link) to reopen the banner.
  window.addEventListener('open-cookie-settings', showBanner);
</script>
