---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms & Conditions — MyCGPA"
  description="Read the terms and conditions for using MyCGPA. Our tools are free, academic resources provided as-is without warranties."
>
  <div class="legal-page">
    <div class="mesh-gradient" aria-hidden="true"></div>
    
    <!-- Hero Section -->
    <section class="legal-hero container-page">
      <div class="hero-content">
        <h1 class="display-xl page-title">Terms &amp; Conditions</h1>
        <p class="body-md subtitle">
          Last updated: June 9, 2026
        </p>
      </div>
    </section>

    <!-- Legal Content -->
    <section class="legal-content container-page">
      <div class="content-wrapper">
        <div class="toc-sidebar">
          <nav aria-label="Table of contents">
            <h2 class="toc-title">Contents</h2>
            <ul class="toc-list">
              <li><a href="#acceptance">1. Acceptance of Terms</a></li>
              <li><a href="#license">2. Use License</a></li>
              <li><a href="#disclaimer">3. Disclaimer</a></li>
              <li><a href="#limitations">4. Limitations of Liability</a></li>
              <li><a href="#accuracy">5. Accuracy of Materials</a></li>
              <li><a href="#links">6. External Links</a></li>
              <li><a href="#modifications">7. Site Modifications</a></li>
              <li><a href="#governing-law">8. Governing Law</a></li>
              <li><a href="#contact">9. Contact Information</a></li>
            </ul>
          </nav>
        </div>

        <div class="content-main card-level-2">
          <div class="legal-intro">
            <p class="body-lg">
              Welcome to MyCGPA. By accessing or using our website, you agree to comply with and be bound by the following Terms &amp; Conditions. Please read them carefully.
            </p>
          </div>

          <section id="acceptance" class="legal-section">
            <h2 class="display-md section-title">1. Acceptance of Terms</h2>
            <p class="body-md">
              By accessing the website at <a href="https://mycgpa.com" class="email-link">mycgpa.com</a>, you are agreeing to be bound by these terms of service, all applicable laws and regulations, and agree that you are responsible for compliance with any applicable local laws.
            </p>
            <p class="body-md">
              If you do not agree with any of these terms, you are prohibited from using or accessing this site. The materials contained in this website are protected by applicable copyright and trademark law.
            </p>
          </section>

          <section id="license" class="legal-section">
            <h2 class="display-md section-title">2. Use License</h2>
            <p class="body-md">
              Permission is granted to temporarily view the materials (information or software) on MyCGPA's website for personal, non-commercial transitory viewing only. This is the grant of a license, not a transfer of title, and under this license you may not:
            </p>
            <ul class="body-md">
              <li>modify or copy the materials;</li>
              <li>use the materials for any commercial purpose, or for any public display (commercial or non-commercial);</li>
              <li>attempt to decompile or reverse engineer any software or calculation scripts contained on MyCGPA's website;</li>
              <li>remove any copyright or other proprietary notations from the materials; or</li>
              <li>transfer the materials to another person or "mirror" the materials on any other server.</li>
            </ul>
            <p class="body-md">
              This license shall automatically terminate if you violate any of these restrictions and may be terminated by MyCGPA at any time. Upon terminating your viewing of these materials or upon the termination of this license, you must destroy any downloaded materials in your possession whether in electronic or printed format.
            </p>
          </section>

          <section id="disclaimer" class="legal-section">
            <h2 class="display-md section-title">3. Disclaimer</h2>
            <p class="body-md">
              The materials on MyCGPA's website are provided on an 'as is' basis. MyCGPA makes no warranties, expressed or implied, and hereby disclaims and negates all other warranties including, without limitation, implied warranties or conditions of merchantability, fitness for a particular purpose, or non-infringement of intellectual property or other violation of rights.
            </p>
            <p class="body-md">
              Further, MyCGPA does not warrant or make any representations concerning the accuracy, likely results, or reliability of the use of the materials on its website or otherwise relating to such materials or on any sites linked to this site. The calculations provided by the website are for informational purposes and should not be treated as official academic transcripts.
            </p>
          </section>

          <section id="limitations" class="legal-section">
            <h2 class="display-md section-title">4. Limitations of Liability</h2>
            <p class="body-md">
              In no event shall MyCGPA or its suppliers be liable for any damages (including, without limitation, damages for loss of data or profit, or due to business interruption) arising out of the use or inability to use the materials on MyCGPA's website, even if MyCGPA or a MyCGPA authorized representative has been notified orally or in writing of the possibility of such damage.
            </p>
            <p class="body-md">
              Because some jurisdictions do not allow limitations on implied warranties, or limitations of liability for consequential or incidental damages, these limitations may not apply to you.
            </p>
          </section>

          <section id="accuracy" class="legal-section">
            <h2 class="display-md section-title">5. Accuracy of Materials</h2>
            <p class="body-md">
              The materials appearing on MyCGPA's website could include technical, typographical, or photographic errors. MyCGPA does not warrant that any of the materials on its website are accurate, complete or current.
            </p>
            <p class="body-md">
              MyCGPA may make changes to the materials contained on its website at any time without notice. However MyCGPA does not make any commitment to update the materials. We do make every effort to review university grading guidelines to keep our templates up to date.
            </p>
          </section>

          <section id="links" class="legal-section">
            <h2 class="display-md section-title">6. External Links</h2>
            <p class="body-md">
              MyCGPA has not reviewed all of the sites linked to its website and is not responsible for the contents of any such linked site. The inclusion of any link does not imply endorsement by MyCGPA of the site. Use of any such linked website is at the user's own risk.
            </p>
          </section>

          <section id="modifications" class="legal-section">
            <h2 class="display-md section-title">7. Site Terms of Use Modifications</h2>
            <p class="body-md">
              MyCGPA may revise these terms of service for its website at any time without notice. By using this website you are agreeing to be bound by the then current version of these Terms &amp; Conditions.
            </p>
          </section>

          <section id="governing-law" class="legal-section">
            <h2 class="display-md section-title">8. Governing Law</h2>
            <p class="body-md">
              These terms and conditions are governed by and construed in accordance with standard internet regulations and the laws of the operating jurisdiction, and you irrevocably submit to the exclusive jurisdiction of the courts in that State or location.
            </p>
          </section>

          <section id="contact" class="legal-section">
            <h2 class="display-md section-title">9. Contact Information</h2>
            <p class="body-md">
              If you have any questions or require clarification about these Terms &amp; Conditions, please contact our support team:
            </p>
            <div class="contact-info">
              <p class="body-md">
                <strong>Email:</strong> <a href="mailto:support@mycgpa.com" class="email-link">support@mycgpa.com</a>
              </p>
              <p class="body-md">
                <strong>Response Time:</strong> We aim to respond to all terms and policy questions within 48 hours.
              </p>
            </div>
          </section>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="legal-cta container-page">
      <div class="cta-inner card-level-3">
        <h2 class="display-lg cta-title">Calculate your scores worry-free</h2>
        <p class="body-md cta-desc">
          Ready to calculate your GPA or CGPA? Explore our university calculators now.
        </p>
        <div class="cta-buttons">
          <a href="/#calculator" class="btn-primary">Try Calculator</a>
          <a href="/universities" class="btn-secondary">Explore Universities</a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .legal-page {
    position: relative;
    padding-bottom: var(--spacing-5xl);
  }

  .legal-hero {
    position: relative;
    z-index: 1;
    padding-top: var(--spacing-4xl);
    padding-bottom: var(--spacing-2xl);
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-title {
    color: var(--color-ink);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-mute);
    margin: 0;
  }

  /* Content Layout */
  .legal-content {
    margin-top: var(--spacing-xl);
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--spacing-2xl);
    align-items: start;
  }

  /* Table of Contents */
  .toc-sidebar {
    position: sticky;
    top: 80px;
  }

  .toc-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 var(--spacing-sm) 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxs);
  }

  .toc-list a {
    display: block;
    padding: var(--spacing-xs) 0;
    font-size: 14px;
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s ease;
    line-height: 1.4;
  }

  .toc-list a:hover {
    color: var(--color-link);
  }

  /* Main Content */
  .content-main {
    background-color: var(--color-canvas);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    border: 1px solid var(--color-hairline);
  }

  .legal-intro {
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--color-hairline);
    margin-bottom: var(--spacing-xl);
  }

  .legal-intro p {
    color: var(--color-body);
    margin: 0;
    line-height: 1.7;
  }

  .legal-section {
    margin-bottom: var(--spacing-2xl);
  }

  .legal-section:last-child {
    margin-bottom: 0;
  }

  .section-title {
    color: var(--color-ink);
    margin-top: 0;
    margin-bottom: var(--spacing-md);
    scroll-margin-top: 100px;
  }

  .legal-section p {
    color: var(--color-body);
    line-height: 1.7;
    margin-bottom: var(--spacing-md);
  }

  .legal-section p:last-child {
    margin-bottom: 0;
  }

  .legal-section ul {
    margin: var(--spacing-md) 0;
    padding-left: var(--spacing-lg);
    color: var(--color-body);
    line-height: 1.7;
  }

  .legal-section li {
    margin-bottom: var(--spacing-xs);
  }

  .legal-section strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  .contact-info {
    background-color: var(--color-canvas-soft-2);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-top: var(--spacing-md);
  }

  .contact-info p {
    margin-bottom: var(--spacing-sm);
  }

  .contact-info p:last-child {
    margin-bottom: 0;
  }

  .email-link {
    color: var(--color-link);
    text-decoration: none;
    font-weight: 500;
  }

  .email-link:hover {
    text-decoration: underline;
  }

  /* CTA Section */
  .legal-cta {
    margin-top: var(--spacing-4xl);
  }

  .cta-inner {
    background-color: var(--color-canvas-soft-2);
    border-radius: var(--radius-xl);
    padding: var(--spacing-3xl);
    text-align: center;
    border: 1px solid var(--color-hairline);
    max-width: 900px;
    margin: 0 auto;
  }

  .cta-title {
    color: var(--color-ink);
    margin-top: 0;
    margin-bottom: var(--spacing-sm);
  }

  .cta-desc {
    color: var(--color-body);
    margin: 0 0 var(--spacing-xl) 0;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 var(--spacing-lg);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-on-primary);
    background-color: var(--color-ink);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 var(--spacing-lg);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .btn-secondary:hover {
    background-color: var(--color-canvas-soft-2);
  }

  /* Responsive Design */
  @media (max-width: 991px) {
    .content-wrapper {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .toc-sidebar {
      position: static;
      background-color: var(--color-canvas-soft-2);
      border-radius: var(--radius-md);
      padding: var(--spacing-lg);
    }

    .toc-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-xs);
    }
  }

  @media (max-width: 767px) {
    .legal-hero {
      padding-top: var(--spacing-2xl);
    }

    .content-main {
      padding: var(--spacing-lg);
    }

    .toc-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 479px) {
    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }
  }
</style>
