---
import Layout from '../layouts/Layout.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Mushfiq Nehal',
  url: 'https://www.mushfiqnehal.dev/',
  email: 'hello@mushfiqnehal.dev',
  jobTitle: 'Software Engineer (Full Stack)',
  sameAs: ['https://www.mushfiqnehal.dev/'],
};
---

<Layout
  title="About Us — Academic Calculators | MyCGPA"
  description="Learn about MyCGPA, our mission to simplify grade tracking for students worldwide, and our values of accuracy, privacy, and simplicity."
  schema={personSchema}
>
  <div class="about-page">
    <div class="mesh-gradient" aria-hidden="true"></div>
    
    <!-- Hero Section -->
    <section class="about-hero container-page">
      <div class="hero-content">
        <h1 class="display-xl page-title">About MyCGPA</h1>
        <p class="body-lg subtitle">
          Empowering students worldwide with precise, accessible, and privacy-first academic calculators.
        </p>
      </div>
    </section>

    <!-- Mission & Story -->
    <section class="about-story container-page">
      <div class="grid-layout">
        <div class="story-card card-level-2">
          <h2 class="display-md section-title">Our Mission</h2>
          <p class="body-md">
            At MyCGPA, we believe that academic tracking shouldn't be a source of stress or confusion. Our mission is to provide students, educators, and universities with free, reliable, and instant GPA and CGPA calculators. By tailoring our tools to regional standards, we bridge the gap between complex institutional rules and simple user interfaces.
          </p>
        </div>
        
        <div class="story-card card-level-2">
          <h2 class="display-md section-title">Why We Built This</h2>
          <p class="body-md">
            Academic grading systems vary wildly. A student in Bangladesh uses a different scale than one in India or Pakistan. Calculating your cumulative average shouldn't require spreadsheet expertise or reading through dense policy documents. We built MyCGPA to offer a seamless, automated, and beautiful solution tailored to each region's specific grading systems.
          </p>
        </div>
      </div>
    </section>

    <!-- Core Values -->
    <section class="about-values container-page">
      <h2 class="display-lg values-title text-center">Our Core Pillars</h2>
      <div class="values-grid">
        <div class="value-item card-level-1">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
              <path d="m9 12 2 2 4-4"></path>
            </svg>
          </div>
          <h3 class="display-sm">100% Accuracy</h3>
          <p class="body-sm">
            We meticulously check university regulations to ensure that every calculation, credit weighting, and grade conversion perfectly aligns with official grading systems.
          </p>
        </div>

        <div class="value-item card-level-1">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a10 10 0 1 0 10 10H12V2z"></path>
              <path d="M12 2a10 10 0 0 1 10 10h-10V2z"></path>
              <path d="M12 12L2.7 6.8"></path>
              <path d="M12 12v10"></path>
              <path d="M12 12l9.3-5.2"></path>
            </svg>
          </div>
          <h3 class="display-sm">Simplicity First</h3>
          <p class="body-sm">
            No registration, no paywalls, and no complicated setups. Input your grades and get results instantly with standard key-binds and an intuitive interface.
          </p>
        </div>

        <div class="value-item card-level-1">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <h3 class="display-sm">Privacy-First</h3>
          <p class="body-sm">
            We do not collect or store your grades, GPA, or personal data. Your details are processed entirely in your browser, keeping your academic transcripts private.
          </p>
        </div>

        <div class="value-item card-level-1">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </div>
          <h3 class="display-sm">Global Support</h3>
          <p class="body-sm">
            From the UGC scale in Bangladesh, to IITs in India, and HEC standards in Pakistan, we aim to cover all major universities and grading systems.
          </p>
        </div>
      </div>
    </section>

    <!-- Meet the Developer -->
    <section class="about-developer container-page">
      <div class="developer-card card-level-2">
        <div class="developer-avatar" aria-hidden="true">MN</div>
        <div class="developer-info">
          <span class="caption-mono developer-eyebrow">Built &amp; maintained by</span>
          <h2 class="display-md developer-name">Mushfiq Nehal</h2>
          <p class="body-md developer-desc">
            Full-stack software engineer and researcher who builds and personally maintains MyCGPA, keeping university grading templates accurate and up to date.
          </p>
          <div class="developer-links">
            <a href="https://www.mushfiqnehal.dev/" class="developer-link" target="_blank" rel="noopener noreferrer">
              Portfolio &amp; work
            </a>
            <a href="mailto:hello@mushfiqnehal.dev" class="developer-link">
              hello@mushfiqnehal.dev
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="about-cta container-page">
      <div class="cta-inner card-level-3">
        <h2 class="display-lg cta-title">Ready to calculate your scores?</h2>
        <p class="body-md cta-desc">
          Get started with our free, instant calculator or browse university-specific grading tools.
        </p>
        <div class="cta-buttons">
          <a href="/#calculator" class="btn-primary">Go to Calculator</a>
          <a href="/universities" class="btn-secondary">Explore Universities</a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .about-page {
    position: relative;
    padding-bottom: var(--spacing-5xl);
  }

  .about-hero {
    position: relative;
    z-index: 1;
    padding-top: var(--spacing-4xl);
    padding-bottom: var(--spacing-2xl);
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-title {
    color: var(--color-ink);
    margin-bottom: var(--spacing-sm);
  }

  .subtitle {
    color: var(--color-body);
    margin: 0;
  }

  /* Story Grid */
  .about-story {
    margin-top: var(--spacing-xl);
  }

  .grid-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
  }

  .story-card {
    background-color: var(--color-canvas);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    border: 1px solid var(--color-hairline);
  }

  .section-title {
    color: var(--color-ink);
    margin-top: 0;
    margin-bottom: var(--spacing-sm);
  }

  /* Values Grid */
  .about-values {
    margin-top: var(--spacing-4xl);
  }

  .values-title {
    color: var(--color-ink);
    margin-bottom: var(--spacing-2xl);
  }

  .text-center {
    text-align: center;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-lg);
  }

  .value-item {
    background-color: var(--color-canvas);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    border: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .value-item:hover {
    transform: translateY(-4px);
    border-color: var(--color-hairline-strong);
  }

  .value-icon {
    color: var(--color-link);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: var(--color-link-bg-soft);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .value-item h3 {
    color: var(--color-ink);
    margin: 0;
  }

  .value-item p {
    color: var(--color-body);
    margin: 0;
    line-height: 1.6;
  }

  /* Meet the Developer */
  .about-developer {
    margin-top: var(--spacing-4xl);
  }

  .developer-card {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-xl);
    background-color: var(--color-canvas);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    border: 1px solid var(--color-hairline);
    max-width: 900px;
    margin: 0 auto;
  }

  .developer-avatar {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    background-color: var(--color-link-bg-soft);
    color: var(--color-link);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.5px;
  }

  .developer-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxs);
  }

  .developer-eyebrow {
    color: var(--color-mute);
  }

  .developer-name {
    margin: 0;
    color: var(--color-ink);
  }

  .developer-desc {
    margin: var(--spacing-xs) 0 var(--spacing-sm) 0;
    color: var(--color-body);
    line-height: 1.6;
    max-width: 560px;
  }

  .developer-links {
    display: flex;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .developer-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-link);
    text-decoration: none;
  }

  .developer-link:hover {
    text-decoration: underline;
  }

  /* CTA */
  .about-cta {
    margin-top: var(--spacing-4xl);
  }

  .cta-inner {
    background-color: var(--color-canvas-soft-2);
    border-radius: var(--radius-xl);
    padding: var(--spacing-3xl);
    text-align: center;
    border: 1px solid var(--color-hairline);
    max-width: 900px;
    margin: 0 auto;
  }

  .cta-title {
    color: var(--color-ink);
    margin-top: 0;
    margin-bottom: var(--spacing-sm);
  }

  .cta-desc {
    color: var(--color-body);
    margin: 0 0 var(--spacing-xl) 0;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 var(--spacing-lg);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-on-primary);
    background-color: var(--color-ink);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 var(--spacing-lg);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .btn-secondary:hover {
    background-color: var(--color-canvas-soft-2);
  }

  /* Responsive Design */
  @media (max-width: 991px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .grid-layout {
      grid-template-columns: 1fr;
    }
    
    .about-hero {
      padding-top: var(--spacing-2xl);
    }

    .developer-card {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--spacing-lg);
    }
  }

  @media (max-width: 479px) {
    .values-grid {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn-primary, .btn-secondary {
      width: 100%;
    }
  }
</style>
