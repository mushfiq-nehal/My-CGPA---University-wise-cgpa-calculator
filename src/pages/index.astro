---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Calculator from '../components/Calculator.astro';
import FormulaSection from '../components/FormulaSection.astro';
import UniversitiesPreview from '../components/UniversitiesPreview.astro';
import SeoContent from '../components/SeoContent.astro';
import FaqSection from '../components/FaqSection.astro';

const faqs = [
  {
    question: "What is CGPA?",
    answer: "CGPA stands for Cumulative Grade Point Average — the weighted average of every graded course you have completed, across all semesters. Each course grade becomes a grade point, weighted by that course's credit hours, so a 4-credit course affects your CGPA twice as much as a 2-credit one: <code>CGPA = Σ(Credit Hours × Grade Point) ÷ Σ(Credit Hours)</code>."
  },
  {
    question: "How do I calculate my CGPA?",
    answer: "Multiply each course's grade point by its credit hours, add up all those products, then divide by your total credit hours: <code>CGPA = Σ(Credits × Grade Points) ÷ Σ(Credits)</code>. For example, an A (4.00) in a 3-credit course and a B (3.00) in a 2-credit course gives (4.00×3 + 3.00×2) ÷ 5 = 3.60. Because grading scales differ between universities, pick your institution above so the right letter-to-point mapping is applied."
  },
  {
    question: "How do I use this calculator?",
    answer: "Choose your country and university, then enter each course's grade and credit hours. The calculator converts letters to grade points using your university's official scale, computes the weighted total, and divides by your total credits. You can add or remove courses at any time, and download the result as a PDF report."
  },
  {
    question: "How do I convert SGPA to CGPA?",
    answer: "Take the weighted average of your semester GPAs, using each semester's credit total as the weight: <code>CGPA = Σ(SGPA × Semester Credits) ÷ Total Credits</code>. You cannot simply average your SGPA values unless every semester carried exactly the same number of credits — a heavier semester should pull the average further."
  },
  {
    question: "How do I convert semester GPA to CGPA?",
    answer: "Enter each semester's GPA alongside the credit hours you earned that semester. The calculator multiplies each GPA by its credits, sums the results, and divides by your total credits. A single semester's GPA reflects only that term; CGPA reflects your whole academic record to date."
  },
  {
    question: "How do I convert CGPA to a percentage?",
    answer: "Multiply your CGPA by the conversion factor your academic board specifies. Under CBSE and UGC guidelines in India the factor is 9.5, so a CGPA of 8.0 is about 76%. Some institutions use a factor of 10 instead, and on a 4.0 scale a common approximation is CGPA × 25. Check your own university's rule before quoting a figure on an application — these factors are approximations, not official equivalences."
  },
  {
    question: "How do I convert a percentage to CGPA?",
    answer: "Divide your percentage by the same conversion factor your board uses. On a 10-point CBSE scale, 76% ÷ 9.5 gives a CGPA of roughly 8.0. As with the reverse conversion, the result is an approximation — universities differ in how they map percentages onto grade points."
  },
  {
    question: "What are credit hours, and why do they matter?",
    answer: "Credit hours measure how much weight a course carries, usually reflecting its contact hours per week. They are the denominator in the CGPA formula, which means a high grade in a 4-credit course lifts your CGPA considerably more than the same grade in a 1-credit course. This is also why dropping a heavily weighted course can shift your average more than you would expect."
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
};
---

<Layout
  title="CGPA Calculator — Free GPA & CGPA Calculator | MyCGPA"
  description="Free CGPA and GPA calculator for Bangladesh, India, and Pakistan universities. Supports UGC Bangladesh, IIT, HEC Pakistan grading systems. Calculate your CGPA instantly — no signup required."
  schema={schema}
>
  <Hero />
  <Calculator />
  <FormulaSection />
  <UniversitiesPreview />
  <SeoContent />
  <FaqSection faqs={faqs} />
  <script>
    // Scroll to the calculator section by default when no specific hash is set
    if (!window.location.hash) {
      const calculator = document.getElementById('calculator');
      if (calculator) {
        calculator.scrollIntoView({ behavior: 'instant' });
      }
    }
  </script>
</Layout>

